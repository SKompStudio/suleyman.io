# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

.vscode
# dependencies
/node_modules
/.pnp
.pnp.js

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# local env files
.env*.local
.env
.env.tmp

# vercel
.vercel

# generated files
/public/rss/

# typescript incremental build info
tsconfig.tsbuildinfo

# latex build artifacts (keep .tex + .pdf, ignore intermediates)
public/*.aux
public/*.log
public/*.out
public/*.fls
public/*.fdb_latexmk
public/*.synctex.gz

# never track editor/backup copies
*.bak

.podcasthub-verify.png
