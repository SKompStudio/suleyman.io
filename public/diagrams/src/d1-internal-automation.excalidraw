    {
      "type": "text",
      "id": "uh_header",
      "x": 82,
      "y": 1154,
      "width": 700,
      "height": 26,
      "text": "UNDER THE HOOD  ·  the parts that aren't generic",
      "originalText": "UNDER THE HOOD  ·  the parts that aren't generic",
      "fontSize": 20,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#E8EDF2",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
