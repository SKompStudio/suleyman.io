    {
      "type": "text",
      "id": "ev_fsm_code",
      "x": 718,
      "y": 528,
      "width": 430,
      "height": 70,
      "text": "gmail.modify(thread_id,\n  add=[\"processing\"], remove=[\"inbox\"])\n# gate only ever lists inbox -> never double-runs",
      "originalText": "gmail.modify(thread_id,\n  add=[\"processing\"], remove=[\"inbox\"])\n# gate only ever lists inbox -> never double-runs",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
