    {
      "type": "text",
      "id": "uhB_code_c",
      "x": 776,
      "y": 1424,
      "width": 592,
      "height": 72,
      "text": "# spawn the worker, sandboxed\nsystemd-run --user --scope --collect \\\n  bwrap --unshare-all --tmpfs $HOME --ro-bind /usr /usr \\\n        --bind $WORK_DIR $WORK_DIR  --  agent -p \"$JOB\"",
