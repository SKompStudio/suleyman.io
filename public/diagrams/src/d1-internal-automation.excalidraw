    },
    {
      "type": "text",
      "id": "uh_sub",
      "x": 82,
      "y": 1184,
      "width": 1000,
      "height": 18,
      "text": "two mechanisms a senior engineer will recognize: a crash-safe exactly-once claim, and a sandbox around untrusted input",
      "originalText": "two mechanisms a senior engineer will recognize: a crash-safe exactly-once claim, and a sandbox around untrusted input",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 700012,
      "version": 1,
      "versionNonce": 700013,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "uhA_h",
      "x": 82,
      "y": 1228,
      "width": 560,
      "height": 20,
      "text": "A.  A dead worker can't strand a thread",
      "originalText": "A.  A dead worker can't strand a thread",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5BC8FF",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 710001,
      "version": 1,
      "versionNonce": 710002,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.25
    },
    {
      "type": "text",
      "id": "uhA_d",
      "x": 82,
      "y": 1254,
      "width": 600,
      "height": 34,
      "text": "if a worker dies after it claims a thread but before it finishes,\nthe thread is stuck in processing. a sweeper recovers it.",
      "originalText": "if a worker dies after it claims a thread but before it finishes,\nthe thread is stuck in processing. a sweeper recovers it.",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
