    {
      "type": "text",
      "id": "uhB_d",
      "x": 760,
      "y": 1254,
      "width": 620,
      "height": 34,
      "text": "the worker reads third-party PDFs while holding an API key,\nso the spawn runs it jailed with a throwaway home directory.",
      "originalText": "the worker reads third-party PDFs while holding an API key,\nso the spawn runs it jailed with a throwaway home directory.",
