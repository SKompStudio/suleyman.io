    {
      "type": "text",
      "id": "uhA_code_c",
      "x": 98,
      "y": 1424,
      "width": 572,
      "height": 72,
      "text": "# recover a thread stranded mid-processing\nif now - first_seen[thread] > TTL:\n    if attempts[thread] < 3: relabel(thread, to=\"inbox\")   # re-drive\n    else:                    relabel(thread, to=\"failed\")  # park",
      "originalText": "# recover a thread stranded mid-processing\nif now - first_seen[thread] > TTL:\n    if attempts[thread] < 3: relabel(thread, to=\"inbox\")   # re-drive\n    else:                    relabel(thread, to=\"failed\")  # park",
      "fontSize": 11.5,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#4ADE80",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
