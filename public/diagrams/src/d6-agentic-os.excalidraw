    {
      "type": "text", "id": "conductor_t", "x": 480, "y": 648, "width": 400, "height": 96,
      "text": "Claude Code\nthe conductor\n\nreads intent, picks the skill,\nfans out the work", "originalText": "Claude Code\nthe conductor\n\nreads intent, picks the skill,\nfans out the work",
