      "x": 98,
      "y": 1374,
      "width": 548,
      "height": 104,
      "text": "# spawn the worker, sandboxed   (watcher_common/spawn.py)\nsystemd-run --user --scope --collect \\\n  bwrap --unshare-all --die-with-parent=no \\\n    --tmpfs /home/sk  --ro-bind /usr /usr \\\n    --bind $DEAL_DIR $DEAL_DIR  --  claude -p \"$JOB\"",
      "originalText": "# spawn the worker, sandboxed   (watcher_common/spawn.py)\nsystemd-run --user --scope --collect \\\n  bwrap --unshare-all --die-with-parent=no \\\n    --tmpfs /home/sk  --ro-bind /usr /usr \\\n    --bind $DEAL_DIR $DEAL_DIR  --  claude -p \"$JOB\"",
      "fontSize": 11.5,
      "fontFamily": 3,
      "textAlign": "left",
