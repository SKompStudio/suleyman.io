    {
      "type": "text", "id": "conductor_note_h", "x": 1012, "y": 620, "width": 420, "height": 20,
      "text": "WHY A SINGLE HUB", "originalText": "WHY A SINGLE HUB",
      "fontSize": 14, "fontFamily": 3, "textAlign": "left", "verticalAlign": "top",
      "strokeColor": "#E8B84B", "backgroundColor": "transparent", "fillStyle": "solid",
      "strokeWidth": 1, "strokeStyle": "solid", "roughness": 0, "opacity": 100, "angle": 0,
      "seed": 300023, "version": 1, "versionNonce": 300024, "isDeleted": false,
      "groupIds": [], "boundElements": null, "link": null, "locked": false, "containerId": null, "lineHeight": 1.25
    },
    {
      "type": "text", "id": "conductor_note_b", "x": 1012, "y": 650, "width": 426, "height": 130,
      "text": "Every request - typed, spoken, or emailed -\nlands in one place. The hub holds the context,\nchooses which domain skill is right, and hands\noff. No skill talks to another skill directly;\nthey only answer the conductor. One brain,\nmany interchangeable hands.",
      "originalText": "Every request - typed, spoken, or emailed -\nlands in one place. The hub holds the context,\nchooses which domain skill is right, and hands\noff. No skill talks to another skill directly;\nthey only answer the conductor. One brain,\nmany interchangeable hands.",
