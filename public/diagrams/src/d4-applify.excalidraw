    {
      "type": "text",
      "id": "uh_code_a_t",
      "x": 98,
      "y": 1352,
      "width": 590,
      "height": 90,
      "text": "// each await is a durable checkpoint\nconst entries = await step.run(\"extract-entries\", () => extract(resume))\nconst scores  = await step.run(\"score-fit\",       () => score(entries, job))\n// crash here -> retry skips the two above, resumes from this one\nconst draft   = await step.run(\"tailor-sections\", () => tailor(scores))",
      "originalText": "// each await is a durable checkpoint\nconst entries = await step.run(\"extract-entries\", () => extract(resume))\nconst scores  = await step.run(\"score-fit\",       () => score(entries, job))\n// crash here -> retry skips the two above, resumes from this one\nconst draft   = await step.run(\"tailor-sections\", () => tailor(scores))",
