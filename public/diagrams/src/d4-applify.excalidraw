    {
      "type": "text",
      "id": "uh_sub",
      "x": 82,
      "y": 1128,
      "width": 1280,
      "height": 18,
      "text": "two mechanisms a senior engineer will recognize: a multi-minute LLM job that survives a crash, and model output that is forced to fit a schema.",
      "originalText": "two mechanisms a senior engineer will recognize: a multi-minute LLM job that survives a crash, and model output that is forced to fit a schema.",
      "fontSize": 14,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
