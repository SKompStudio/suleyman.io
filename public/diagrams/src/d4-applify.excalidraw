    },
    {
      "type": "text",
      "id": "uh_sech_a",
      "x": 82,
      "y": 1172,
      "width": 640,
      "height": 22,
      "text": "A.  A long LLM job that survives a crash",
      "originalText": "A.  A long LLM job that survives a crash",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5BC8FF",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
