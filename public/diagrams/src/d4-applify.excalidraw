    {
      "type": "text",
      "id": "uh_code_b_t",
      "x": 786,
      "y": 1352,
      "width": 632,
      "height": 90,
      "text": "import { zodTextFormat } from \"openai/helpers/zod\"\n// .parse() validates against the schema before it returns\nconst res = await openai.responses.parse({\n  model: \"gpt-4o\",  input: prompt,\n  text: { format: zodTextFormat(TailoredResume, \"resume\") } })\nconst resume = res.output_parsed   // fully typed, schema-checked",
      "originalText": "import { zodTextFormat } from \"openai/helpers/zod\"\n// .parse() validates against the schema before it returns\nconst res = await openai.responses.parse({\n  model: \"gpt-4o\",  input: prompt,\n  text: { format: zodTextFormat(TailoredResume, \"resume\") } })\nconst resume = res.output_parsed   // fully typed, schema-checked",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#5BC8FF",
      "backgroundColor": "transparent",
