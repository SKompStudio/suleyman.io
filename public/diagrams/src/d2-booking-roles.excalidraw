    },
    {
      "type": "text",
      "id": "code_txt",
      "x": 98,
      "y": 1188,
      "width": 672,
      "height": 160,
      "text": "// one client per request, scoped to the studio in the JWT\nexport function scopedPrisma(studioId: string) {\n  return base.$extends({\n    query: {\n      $allModels: {\n        $allOperations({ args, query }) {\n          args.where = { ...args.where, studioId }   // injected\n          return query(args)\n        },\n      },\n    },\n  })\n}",
      "originalText": "// one client per request, scoped to the studio in the JWT\nexport function scopedPrisma(studioId: string) {\n  return base.$extends({\n    query: {\n      $allModels: {\n        $allOperations({ args, query }) {\n          args.where = { ...args.where, studioId }   // injected\n          return query(args)\n        },\n      },\n    },\n  })\n}",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#3E7E9C",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 514020,
      "version": 1,
      "versionNonce": 514021,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.32
    },
