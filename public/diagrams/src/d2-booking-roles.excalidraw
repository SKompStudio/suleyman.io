    {
      "type": "text",
      "id": "uh_why",
      "x": 82,
      "y": 1102,
      "width": 870,
      "height": 18,
      "text": "why not Postgres RLS: the studioId comes from the signed JWT, so the app owns the boundary in one place; forget the wrapper and you get nothing, never another studio's rows.",
      "originalText": "why not Postgres RLS: the studioId comes from the signed JWT, so the app owns the boundary in one place; forget the wrapper and you get nothing, never another studio's rows.",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 513001,
      "version": 1,
      "versionNonce": 513002,
      "isDeleted": false,
      "groupIds": [],
      "boundElements": null,
      "link": null,
      "locked": false,
      "containerId": null,
      "lineHeight": 1.3
    },
    {
      "type": "text",
      "id": "code_cap",
      "x": 82,
      "y": 1150,
      "width": 600,
      "height": 16,
      "text": "the wrapper  ·  scopedPrisma.ts",
      "originalText": "the wrapper  ·  scopedPrisma.ts",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 514001,
      "version": 1,
      "versionNonce": 514002,
      "isDeleted": false,
      "groupIds": [],
