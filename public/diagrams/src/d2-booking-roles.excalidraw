    },
    {
      "type": "rectangle",
      "id": "code_box",
      "x": 82,
      "y": 1174,
      "width": 700,
      "height": 222,
      "strokeColor": "#1A2330",
      "backgroundColor": "#0A0D12",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 514010,
      "version": 1,
      "versionNonce": 514011,
      "isDeleted": false,
      "groupIds": [],
