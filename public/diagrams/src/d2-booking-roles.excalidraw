      "type": "text",
      "id": "headline",
      "x": 82,
      "y": 50,
      "width": 1180,
      "height": 46,
      "text": "Four roles, one codebase, one database. No studio ever sees another's.",
      "originalText": "Four roles, one codebase, one database. No studio ever sees another's.",
      "fontSize": 32,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
