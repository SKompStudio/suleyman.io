      "id": "uhB_code_c1",
      "x": 776,
      "y": 1332,
      "width": 588,
      "height": 56,
      "text": "// one client per request, bound to the tenant  (lib/db.ts)\nconst db = scopedPrisma(session.studioId)\nawait db.booking.findMany({ where: { classId } })",
      "originalText": "// one client per request, bound to the tenant  (lib/db.ts)\nconst db = scopedPrisma(session.studioId)\nawait db.booking.findMany({ where: { classId } })",
