    {
      "type": "text",
      "id": "uh_sub",
      "x": 82,
      "y": 1086,
      "width": 1000,
      "height": 18,
      "text": "two mechanisms a senior engineer will recognize: an out-of-band payment settlement, and tenant isolation enforced in the data layer",
      "originalText": "two mechanisms a senior engineer will recognize: an out-of-band payment settlement, and tenant isolation enforced in the data layer",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#7C8896",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "angle": 0,
      "seed": 520005,
