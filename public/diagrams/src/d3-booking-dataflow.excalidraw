    },
    {
      "type": "text",
      "id": "uhA_sech",
      "x": 82,
      "y": 1132,
      "width": 560,
      "height": 20,
      "text": "A.  Checkout returns before the money settles",
      "originalText": "A.  Checkout returns before the money settles",
      "fontSize": 16,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "strokeColor": "#A78BFA",
      "backgroundColor": "transparent",
